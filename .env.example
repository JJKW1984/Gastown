# =============================================================================
# Gastown — LLM Provider Configuration
# Copy this file to .env and fill in your credentials.
# Only one provider block needs to be configured.
# =============================================================================

# --- Anthropic (default) ---
ANTHROPIC_API_KEY=sk-ant-...
GASTOWN_MODEL=anthropic/claude-sonnet-4-6

# --- Azure OpenAI ---
# Uncomment and set GASTOWN_MODEL=azure/<your-deployment-name>
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-01
# GASTOWN_MODEL=azure/gpt-4o

# --- Ollama (local) ---
# Uncomment and set GASTOWN_MODEL=ollama/<model-name>
# No API key needed. Ollama must be running at the base URL below.
# OLLAMA_API_BASE=http://localhost:11434
# GASTOWN_MODEL=ollama/llama3

# --- OpenAI ---
# Uncomment and set GASTOWN_MODEL=openai/<model-name>
# OPENAI_API_KEY=sk-...
# GASTOWN_MODEL=openai/gpt-4o

# =============================================================================
# App Configuration
# =============================================================================
GASTOWN_DB_PATH=gastown.db
GASTOWN_MAX_CONCURRENT_POLECATS=4
GASTOWN_STUCK_TIMEOUT_SECONDS=120
GASTOWN_HOST=127.0.0.1
GASTOWN_PORT=8000
